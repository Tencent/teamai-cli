{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc \"teamai hook-dispatch session-start --tool claude-internal 2>/dev/null\" || true"
          }
        ],
        "description": "[teamai] Hook dispatch session-start"
      }
    ],
    "Stop": [
